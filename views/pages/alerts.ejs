<%- include('../partials/head') %><%- include('../partials/nav') %><main><section class="panel"><h1>Alertas de preco</h1><form class="grid-form" method="post"><input name="coinId" placeholder="bitcoin" required><input name="coinName" placeholder="Bitcoin" required><input name="symbol" placeholder="BTC" required><input name="targetPrice" type="number" step="any" placeholder="Preco alvo" required><select name="currency"><option>USD</option><option>BRL</option></select><select name="direction"><option value="above">passar acima</option><option value="below">cair abaixo</option></select><button class="primary">Criar alerta</button></form><p class="muted">Estrutura pronta para futuro envio por e-mail, push ou webhook.</p></section><section class="coin-grid"><% alerts.forEach(a=>{ %><article class="coin-card"><h2><%= a.coin_name %></h2><p><%= a.direction === 'above' ? 'Acima de' : 'Abaixo de' %> <%= a.currency %> <%= Number(a.target_price).toFixed(2) %></p><small><%= a.status %></small></article><% }) %></section></main><%- include('../partials/footer') %>
<% title = coin.symbol.toUpperCase() + 'USD ' + Number(coin.market_data.current_price.usd).toLocaleString('pt-BR', { maximumFractionDigits: Number(coin.market_data.current_price.usd) >= 1000 ? 0 : 4 }) + ' ' + (coin.market_data.price_change_percentage_24h >= 0 ? '▲ +' : '▼ -') + Math.abs(Number(coin.market_data.price_change_percentage_24h || 0)).toFixed(2) + '% - CryptoScope'; %>
<%- include('../partials/head') %><%- include('../partials/nav') %>
<% const coinImage = coin.id === 'bitcoin' ? '/assets/btc.gif' : coin.image.small; %>
<% const selectedPrice = Number(coin.market_data.current_price.usd || 0); %>
<% const selectedPct = Number(coin.market_data.price_change_percentage_24h || 0); %>
<% const selectedAbs = selectedPct ? selectedPrice * selectedPct / (100 + selectedPct) : 0; %>
<% const selectedMoveClass = selectedPct >= 0 ? 'pos' : 'neg'; %>

<main class="trading-page">
  <section class="trading-layout">
    <div class="chart-workspace">
      <div class="tv-topbar">
        <div class="symbol-switcher">
          <span class="avatar"><%= coin.symbol.toUpperCase().slice(0,1) %></span>
          <div class="coin-search-box">
            <input id="coinSwitcherSearch" value="<%= coin.symbol.toUpperCase() %>USD" autocomplete="off" aria-label="Pesquisar moeda">
            <div id="coinSearchResults" class="coin-search-results"></div>
          </div>
          <button class="round-btn" id="openCoinSearch" title="Pesquisar simbolo">+</button>
        </div>
        <div class="timeframe-strip timeframe-menu-wrap" id="timeframeStrip">
          <button class="timeframe-current active" id="timeframeMenuToggle" type="button" data-period="5m"><span id="timeframeCurrent">5m</span><i></i></button>
          <div class="timeframe-menu" id="timeframeMenu">
            <button class="custom-interval" type="button"><span class="top-icon plus-icon"></span>Adicionar intervalo personalizado...</button>
            <section><header>TICKS</header><button data-period="1t">1 tick</button><button data-period="10t">10 ticks</button><button data-period="100t">100 ticks</button><button data-period="1000t">1000 ticks</button></section>
            <section><header>SEGUNDOS</header><button data-period="1s">1 segundo</button><button data-period="5s">5 segundos</button><button data-period="10s">10 segundos</button><button data-period="15s">15 segundos</button><button data-period="30s">30 segundos</button><button data-period="45s">45 segundos</button></section>
            <section><header>MINUTOS</header><button data-period="1m">1 minuto</button><button data-period="2m">2 minutos</button><button data-period="3m">3 minutos</button><button class="active" data-period="5m">5 minutos</button><button data-period="10m">10 minutos</button><button data-period="15m">15 minutos</button><button data-period="30m">30 minutos</button><button data-period="45m">45 minutos</button></section>
            <section><header>HORAS</header><button data-period="1h">1 hora</button><button data-period="2h">2 horas</button><button data-period="3h">3 horas</button><button data-period="4h">4 horas</button><button data-period="6h">6 horas</button><button data-period="8h">8 horas</button><button data-period="12h">12 horas</button></section>
            <section><header>DIAS</header><button data-period="1d">1 dia</button><button data-period="3d">3 dias</button><button data-period="7d">1 semana</button><button data-period="30d">1 mes</button><button data-period="1y">1 ano</button><button data-period="all">Todos</button></section>
          </div>
        </div>
        <div class="chart-actions">
          <button id="indicatorToggle" type="button"><span class="top-icon indicator-icon"></span>Indicadores</button>
          <button type="button" title="Layout"><span class="top-icon grid-icon"></span></button>
          <button type="button"><span class="top-icon alert-icon"></span>Alerta</button>
          <button type="button"><span class="top-icon replay-icon"></span>Replay</button>
          <button class="ghost icon-only" type="button" title="Desfazer"><span class="top-icon undo-icon"></span></button>
          <button class="ghost icon-only" type="button" title="Refazer"><span class="top-icon redo-icon"></span></button>
        </div>
      </div>
      <div class="chart-body">
        <aside class="drawing-toolbar" id="drawingToolbar">
          <button class="active" data-tool="cursor" title="Cursor"><span class="tool-icon crosshair-icon"></span></button>
          <span class="tool-separator"></span>
          <button data-tool="trend" title="Linha de tendencia"><span class="tool-icon trend-icon"></span></button>
          <button data-tool="horizontal" title="Linha horizontal"><span class="tool-icon horizontal-icon"></span></button>
          <button data-tool="measure" title="Medir"><span class="tool-icon measure-icon"></span></button>
          <button data-tool="levels" title="Niveis"><span class="tool-icon levels-icon"></span></button>
          <span class="tool-separator"></span>
          <button data-tool="brush" title="Desenho livre"><span class="tool-icon brush-icon"></span></button>
          <button data-tool="text" title="Texto"><span class="tool-icon text-icon"></span></button>
          <button data-tool="emoji" title="Emoji"><span class="tool-icon emoji-icon"></span></button>
          <span class="tool-separator"></span>
          <button data-tool="ruler" title="Regua"><span class="tool-icon ruler-icon"></span></button>
          <button data-tool="zoomTool" title="Zoom"><span class="tool-icon zoom-icon"></span></button>
          <span class="tool-separator"></span>
          <button data-tool="magnet" title="Ima"><span class="tool-icon magnet-icon"></span></button>
          <button data-tool="lock-draw" title="Bloquear desenhos"><span class="tool-icon pencil-lock-icon"></span></button>
          <button data-tool="lock" title="Bloquear"><span class="tool-icon lock-icon"></span></button>
          <button data-tool="eye" title="Mostrar/ocultar"><span class="tool-icon eye-icon"></span></button>
          <button data-tool="erase" title="Limpar desenhos"><span class="tool-icon trash-icon"></span></button>
        </aside>
        <div class="chart-main">
          <div class="chart-meta"><span class="pair-name"><img src="<%= coinImage %>" alt=""> <%= coin.name %>/Dolar Americano · <strong id="activeTf">5m</strong> · CoinGecko</span><span id="ohlcText">Abr -- Max -- Min -- Fch --</span><span id="livePrice"><%= fmt.money(selectedPrice,'USD') %></span><span id="liveChange" class="<%= selectedMoveClass %>"><%= fmt.percent(selectedPct) %></span></div>
          <div class="candle-shell"><canvas id="candleChart" data-coin="<%= coin.id %>"></canvas><div id="chartLoading">carregando candles...</div><div class="chart-brand"><img src="/assets/cryptoscope-logo.svg" alt="CryptoScope"></div><div class="price-follow" id="priceFollow"><strong>--</strong><span>--</span></div></div>
          <div class="bottom-time-axis"><span>1D</span><span>5D</span><span>1M</span><span>3M</span><span>6M</span><span>YTD</span><span>1A</span><span>5A</span><span>Todos</span><b id="clockNow"></b></div>
        </div>
      </div>
    </div>
    <aside class="trade-sidebar" id="tradeSidebar"><button class="watchlist-resizer" id="watchlistResizer" title="Redimensionar watchlist"></button>
      <section class="watchlist-panel"><div class="watchlist-head"><b>Watchlist</b><span>v</span><em>+ grid more</em></div><table><thead><tr><th>Simbolo</th><th>Preco</th><th>Var</th><th>Var%</th></tr></thead><tbody id="watchlistRows"><tr><td colspan="4" class="watchlist-loading">carregando ativos...</td></tr></tbody></table></section>
      <section class="watch-fear-card" data-watch-fear style="--value:50">
        <div class="watch-fear-top"><span>Fear & Greed</span><b data-watch-fear-score>--</b></div>
        <div class="watch-fear-bar"><i></i></div>
        <p><span data-watch-fear-label>carregando...</span><small data-watch-fear-time></small></p>
      </section>

      <section class="selected-asset-card <%= selectedMoveClass %>" id="selectedAssetCard" data-current-price="<%= selectedPrice %>">
        <div class="selected-card-top">
          <div class="selected-title"><img src="<%= coinImage %>" alt=""><strong><%= coin.symbol.toUpperCase() %>USD</strong></div>
          <div class="selected-actions"><button title="Grade">grid</button><button title="Editar">edit</button><button title="Mais">...</button></div>
        </div>
        <div class="selected-subtitle"><b><%= coin.name %>/Dolar Americano</b><span>Spot · Cripto</span></div>
        <div class="selected-price-row"><strong class="asset-price"><%= selectedPrice.toLocaleString('en-US', { maximumFractionDigits: 8 }) %></strong><small>USD</small><span id="assetAbsChange" class="<%= selectedMoveClass %>"><%= (selectedAbs >= 0 ? '+' : '-') + Math.round(Math.abs(selectedAbs)).toLocaleString('en-US') + '$' %></span><span id="assetChange24h" class="<%= selectedMoveClass %>"><%= fmt.percent(selectedPct) %></span></div>
        <p class="market-open"><i></i> Mercado aberto</p>
        <a class="selected-news" href="<%= coin.links.homepage[0] || '#' %>" target="_blank"><span>go</span><b>ha 13 horas ·</b> Dados de mercado de <%= coin.name %> atualizados em tempo real</a>
        <div class="selected-stats"><h2>Principais estatisticas</h2><p><span>Volume</span><b><%= fmt.compact(coin.market_data.total_volume.usd) %></b></p><p><span>Volume de negociacao 24h</span><b>$<%= fmt.compact(coin.market_data.total_volume.usd) %></b></p><p><span>Valor de Mercado</span><b>$<%= fmt.compact(coin.market_data.market_cap.usd) %></b></p><p><span>Supply</span><b><%= fmt.compact(coin.market_data.circulating_supply) %> <%= coin.symbol.toUpperCase() %></b></p><p><span>Max 24h</span><b><%= fmt.money(coin.market_data.high_24h.usd,'USD') %></b></p><p><span>Min 24h</span><b><%= fmt.money(coin.market_data.low_24h.usd,'USD') %></b></p></div>
        <button class="selected-collapse" title="Recolher">v</button>
      </section>
    </aside>
  </section>
</main>
<%- include('../partials/footer') %>

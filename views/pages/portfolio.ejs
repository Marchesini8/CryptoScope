<%- include('../partials/head') %><%- include('../partials/nav') %><main><section class="panel"><h1>Minha carteira</h1><form class="grid-form" method="post"><input name="coinId" placeholder="id CoinGecko: bitcoin" required><input name="coinName" placeholder="Nome" required><input name="symbol" placeholder="BTC" required><input name="amountInvested" type="number" step="any" placeholder="Valor investido" required><input name="coinPrice" type="number" step="any" placeholder="Preco da moeda" required><input name="quantity" type="number" step="any" placeholder="Quantidade" required><input name="purchasedAt" type="date"><button class="primary">Adicionar</button></form></section><section class="table-wrap"><table><thead><tr><th>Moeda</th><th>Qtd</th><th>Investido</th><th>Preco compra</th><th>Atual USD</th><th>Resultado</th></tr></thead><tbody><% let total=0, current=0; txs.forEach(t=>{ const p=(prices[t.coin_id]?.usd)||0; total+=Number(t.amount_invested); current+=Number(t.quantity)*p; %><tr><td><%= t.coin_name %> <small><%= t.symbol %></small></td><td><%= Number(t.quantity).toFixed(8) %></td><td>R$ <%= Number(t.amount_invested).toFixed(2) %></td><td><%= Number(t.coin_price).toFixed(2) %></td><td>$ <%= p.toFixed(2) %></td><td class="<%= (Number(t.quantity)*p-Number(t.amount_invested))>=0?'pos':'neg' %>">$ <%= (Number(t.quantity)*p-Number(t.amount_invested)).toFixed(2) %></td></tr><% }) %></tbody></table></section><section class="stats-grid"><div><span>Total investido</span><b>R$ <%= total.toFixed(2) %></b></div><div><span>Valor atual estimado</span><b>$ <%= current.toFixed(2) %></b></div><div><span>Rentabilidade</span><b><%= total ? (((current-total)/total)*100).toFixed(2) : '0.00' %>%</b></div></section></main><%- include('../partials/footer') %>
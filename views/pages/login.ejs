<%- include('../partials/head') %><%- include('../partials/nav') %><main class="auth"><form class="panel narrow" method="post" action="/auth/<%= mode === 'register' ? 'cadastro' : 'login' %>"><h1><%= mode === 'register' ? 'Criar conta' : 'Entrar' %></h1><% errors.forEach(e=>{ %><p class="error"><%= e.msg %></p><% }) %><% if (mode === 'register') { %><label>Nome<input name="name" required></label><% } %><label>E-mail<input name="email" type="email" required></label><label>Senha<input name="password" type="password" required></label><button class="primary">Continuar</button><a href="/auth/<%= mode === 'register' ? 'login' : 'cadastro' %>"><%= mode === 'register' ? 'Ja tenho conta' : 'Criar cadastro' %></a></form></main><%- include('../partials/footer') %>
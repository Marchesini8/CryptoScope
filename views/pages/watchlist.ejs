<%- include('../partials/head') %><%- include('../partials/nav') %><main><section class="panel"><h1>Watchlist</h1><p>Moedas favoritas salvas para acompanhamento rapido.</p></section><section class="coin-grid"><% coins.forEach(c=>{ %><article class="coin-card"><img src="<%= c.image %>"><h2><%= c.name %></h2><p>$ <%= c.current_price %></p><form action="/watchlist/<%= c.id %>/remover" method="post"><button>Remover</button></form></article><% }) %></section></main><%- include('../partials/footer') %>
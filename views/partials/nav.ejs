<header class="topbar">
  <div class="topbar-left">
    <a class="brand" href="/" aria-label="CryptoScope">
      <img src="/assets/cryptoscope-logo.svg" alt="CryptoScope">
    </a>
    <nav class="main-nav" aria-label="Navegacao principal">
      <a href="/">Cryptocurrencies</a>
      <a href="/noticias">Dashboards</a>
      <a href="/moeda/bitcoin">DexScan</a>
      <a href="/conversor-bitcoin-real">Exchanges</a>
      <a href="/chat">Community</a>
      <a href="/calculadora-preco-medio-bitcoin">API</a>
      <a href="/calculadora-lucro-bitcoin">Products</a>
    </nav>
  </div>
  <div class="topbar-actions">
    <% if (user) { %>
      <a href="/carteira">Portfolio</a>
      <a href="/watchlist">Watchlist</a>
      <a href="/alertas">Alerts</a>
      <form action="/auth/logout" method="post"><button type="submit">Sair</button></form>
    <% } else { %>
      <a href="/carteira">Portfolio</a>
      <a href="/watchlist">Watchlist</a>
    <% } %>
    <label class="global-search" aria-label="Buscar">
      <input type="search" placeholder="Search">
    </label>
    <% if (!user) { %><a class="pill login-pill" href="/auth/login" data-auth-open="login">Log In</a><% } %>
  </div>
</header>

<style>
  .auth-modal-root{position:fixed!important;inset:0!important;z-index:10000!important;display:grid!important;place-items:center!important;padding:18px!important;opacity:0!important;visibility:hidden!important;pointer-events:none!important;background:transparent!important;transition:opacity .18s ease,visibility .18s ease!important}
  .auth-modal-root.open{opacity:1!important;visibility:visible!important;pointer-events:auto!important}
  .auth-backdrop{position:absolute!important;inset:0!important;background:rgba(5,8,15,.74)!important;backdrop-filter:blur(2px)!important}
  .auth-dialog{position:relative!important;width:min(420px,calc(100vw - 28px))!important;background:#20232e!important;border:1px solid #30374a!important;border-radius:8px!important;box-shadow:0 24px 80px rgba(0,0,0,.58)!important;padding:24px!important;color:#f4f7ff!important;transform:translateY(16px) scale(.97)!important;opacity:.4!important;transition:transform .24s cubic-bezier(.2,.8,.2,1),opacity .2s ease!important}
  .auth-modal-root.open .auth-dialog{transform:translateY(0) scale(1)!important;opacity:1!important}
  .auth-close{position:absolute!important;right:14px!important;top:12px!important;width:28px!important;height:28px!important;padding:0!important;border:0!important;background:transparent!important;color:#aeb7c8!important;font-size:20px!important}
  .auth-title{margin:8px 0 8px!important;text-align:center!important;color:#fff!important;font-size:25px!important;line-height:1.1!important;font-weight:900!important}
  .auth-copy{margin:0 auto 22px!important;max-width:310px!important;text-align:center!important;color:#aeb7c8!important;font-size:13px!important;line-height:1.45!important}
  .google-login-shell{display:grid!important;gap:10px!important}
  .google-login-button{height:46px!important;width:100%!important;display:flex!important;align-items:center!important;justify-content:center!important;gap:11px!important;border:1px solid #596174!important;border-radius:7px!important;background:#fff!important;color:#202124!important;font-size:14px!important;font-weight:800!important}
  .google-login-button:hover{background:#f7f9ff!important;border-color:#8d96aa!important}
  .google-icon{width:19px!important;height:19px!important;display:block!important}
  .google-error{min-height:18px!important;margin:2px 0 0!important;color:#ff6b7a!important;text-align:center!important;font-size:12px!important}
  .auth-terms{margin:14px 0 0!important;text-align:center!important;color:#8f98aa!important;font-size:11px!important;line-height:1.35!important}
</style>

<div class="auth-modal-root" id="authModal" aria-hidden="true" data-google-client-id="<%= googleClientId %>">
  <div class="auth-backdrop" data-auth-close></div>
  <section class="auth-dialog" role="dialog" aria-modal="true" aria-label="Login com Google">
    <button class="auth-close" type="button" data-auth-close aria-label="Fechar">x</button>
    <h2 class="auth-title">Entrar no CryptoScope</h2>
    <p class="auth-copy">Use sua conta Google para acessar carteira, watchlist, alertas e historico.</p>
    <div class="google-login-shell">
      <button class="google-login-button" type="button" data-google-login>
        <svg class="google-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M21.6 12.23c0-.78-.07-1.53-.2-2.23H12v4.22h5.38a4.6 4.6 0 0 1-2 3.02v2.51h3.24c1.9-1.75 2.98-4.33 2.98-7.52z"/><path fill="#34A853" d="M12 22c2.7 0 4.97-.9 6.63-2.43l-3.24-2.51c-.9.6-2.04.96-3.39.96-2.6 0-4.8-1.76-5.59-4.12H3.06v2.59A10 10 0 0 0 12 22z"/><path fill="#FBBC05" d="M6.41 13.9a6.01 6.01 0 0 1 0-3.8V7.51H3.06a10 10 0 0 0 0 8.98l3.35-2.59z"/><path fill="#EA4335" d="M12 5.98c1.47 0 2.8.51 3.84 1.5l2.87-2.87A9.62 9.62 0 0 0 12 2a10 10 0 0 0-8.94 5.51l3.35 2.59C7.2 7.74 9.4 5.98 12 5.98z"/></svg>
        Continuar com Google
      </button>
      <p class="google-error" data-google-error></p>
    </div>
    <p class="auth-terms">Ao continuar, voce concorda com os termos e a politica de privacidade do CryptoScope.</p>
  </section>
</div>

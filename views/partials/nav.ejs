<header class="topbar">
  <div class="topbar-left">
    <a class="brand" href="/" aria-label="CryptoScope">
      <img src="/assets/cryptoscope-logo.svg" alt="CryptoScope">
    </a>
    <nav class="main-nav" aria-label="Navegacao principal">
      <a href="/">Cryptocurrencies</a>
      <a href="/noticias">Dashboards</a>
      <a href="/moeda/bitcoin">DexScan</a>
      <a href="/conversor-bitcoin-real">Exchanges</a>
      <a href="/chat">Community</a>
      <a href="/calculadora-preco-medio-bitcoin">API</a>
      <a href="/calculadora-lucro-bitcoin">Products</a>
    </nav>
  </div>
  <div class="topbar-actions">
    <% if (user) { %>
      <a href="/carteira">Portfolio</a>
      <a href="/watchlist">Watchlist</a>
      <a href="/alertas">Alerts</a>
      <form action="/auth/logout" method="post"><button type="submit">Sair</button></form>
    <% } else { %>
      <a href="/carteira">Portfolio</a>
      <a href="/watchlist">Watchlist</a>
    <% } %>
    <label class="global-search" aria-label="Buscar">
      <input type="search" placeholder="Search">
    </label>
    <% if (!user) { %><a class="pill login-pill" href="/auth/login" data-auth-open="login">Log In</a><% } %>
  </div>
</header>

<style>
  .auth-modal-root{position:fixed!important;inset:0!important;z-index:10000!important;display:grid!important;place-items:center!important;padding:18px!important;opacity:0!important;visibility:hidden!important;pointer-events:none!important;background:transparent!important;transition:opacity .18s ease,visibility .18s ease!important}
  .auth-modal-root.open{opacity:1!important;visibility:visible!important;pointer-events:auto!important}
  .auth-backdrop{position:absolute!important;inset:0!important;background:rgba(5,8,15,.74)!important;backdrop-filter:blur(2px)!important}
  .auth-dialog{position:relative!important;width:min(430px,calc(100vw - 28px))!important;max-height:92vh!important;overflow:auto!important;background:#20232e!important;border:1px solid #30374a!important;border-radius:8px!important;box-shadow:0 24px 80px rgba(0,0,0,.58)!important;padding:20px 22px 24px!important;color:#f4f7ff!important;transform:translateY(16px) scale(.97)!important;opacity:.4!important;transition:transform .24s cubic-bezier(.2,.8,.2,1),opacity .2s ease!important}
  .auth-modal-root.open .auth-dialog{transform:translateY(0) scale(1)!important;opacity:1!important}
  .auth-close{position:absolute!important;right:14px!important;top:12px!important;width:28px!important;height:28px!important;padding:0!important;border:0!important;background:transparent!important;color:#aeb7c8!important;font-size:20px!important}
  .auth-tabs{display:flex!important;justify-content:center!important;gap:34px!important;margin:0 0 26px!important}.auth-tabs button{position:relative!important;border:0!important;background:transparent!important;padding:0 0 10px!important;color:#9ca6bc!important;font-size:21px!important;font-weight:700!important}.auth-tabs button.active{color:#fff!important}.auth-tabs button.active:after{content:"";position:absolute;left:50%;bottom:0;width:26px;height:5px;border-radius:99px;background:#5b7cff;transform:translateX(-50%)}
  .auth-form{display:grid!important;gap:17px!important}.auth-form label{position:relative!important;display:grid!important;gap:8px!important;color:#fff!important;font-size:12px!important;font-weight:700!important}.auth-form label>a{position:absolute!important;right:0!important;top:0!important;color:#9ca6bc!important}.auth-form input[type="email"],.auth-form input[type="password"]{height:51px!important;background:#151823!important;border:1px solid #495165!important;border-radius:7px!important;color:#eef3ff!important;padding:0 15px!important;font-size:14px!important;font-weight:400!important}.auth-form input:focus{border-color:#5575ff!important;box-shadow:0 0 0 3px rgba(69,102,255,.26)!important;outline:none!important}.auth-form label>span{position:relative!important}.auth-form i{position:absolute!important;right:15px!important;top:50%!important;transform:translateY(-50%)!important;color:#8994a8!important;font-style:normal!important;font-size:11px!important}
  .auth-submit{height:37px!important;margin-top:12px!important;border:0!important;border-radius:7px!important;background:#3550b0!important;color:#dce4f2!important;font-weight:800!important}.auth-separator{display:grid!important;grid-template-columns:1fr auto 1fr!important;align-items:center!important;gap:14px!important;margin:25px 0 18px!important;color:#fff!important;font-weight:800!important}.auth-separator:before,.auth-separator:after,.auth-email-title span{content:"";display:block;height:1px;background:#343a4b}
  .auth-social{display:grid!important;gap:14px!important}.auth-social button{height:43px!important;display:flex!important;align-items:center!important;justify-content:center!important;gap:10px!important;border:1px solid #596174!important;border-radius:7px!important;background:#20232e!important;color:#fff!important;font-weight:800!important}.auth-signup-first,.auth-signup-form{display:none!important}.auth-modal-root.signup-mode .auth-login-form,.auth-modal-root.signup-mode .auth-login-social,.auth-modal-root.signup-mode .auth-separator{display:none!important}.auth-modal-root.signup-mode .auth-signup-first,.auth-modal-root.signup-mode .auth-signup-form{display:grid!important}.auth-email-title{display:grid!important;grid-template-columns:1fr auto 1fr!important;align-items:center!important;gap:14px!important;margin:12px 0 5px!important;color:#fff!important;font-weight:900!important}.auth-check{grid-template-columns:auto 1fr!important;align-items:start!important}.auth-terms{text-align:center!important;color:#c4cbda!important;font-size:12px!important}
</style>

<div class="auth-modal-root" id="authModal" aria-hidden="true">
  <div class="auth-backdrop" data-auth-close></div>
  <section class="auth-dialog" role="dialog" aria-modal="true" aria-label="Login e cadastro">
    <button class="auth-close" type="button" data-auth-close aria-label="Fechar">x</button>

    <div class="auth-tabs">
      <button type="button" data-auth-tab="login" class="active">Log In</button>
      <button type="button" data-auth-tab="signup">Sign Up</button>
    </div>

    <div class="auth-social auth-signup-first">
      <button type="button"><span class="google-mark">G</span>Continue with Google</button>
      <button type="button"><span class="apple-mark">A</span>Continue with Apple</button>
      <button type="button"><span class="binance-mark">B</span>Continue with Binance</button>
      <button type="button"><span class="wallet-mark">W</span>Continue with Wallet</button>
    </div>

    <form class="auth-form auth-login-form" method="post" action="/auth/login">
      <label>Email Address<input name="email" type="email" placeholder="Enter your email address..." required></label>
      <label>Password<a href="#">Forgot password?</a><span><input name="password" type="password" placeholder="Enter your password..." required><i>hide</i></span></label>
      <button class="auth-submit" type="submit">Log In</button>
    </form>

    <div class="auth-separator"><span>OR</span></div>

    <div class="auth-social auth-login-social">
      <button type="button"><span class="google-mark">G</span>Continue with Google</button>
      <button type="button"><span class="apple-mark">A</span>Continue with Apple</button>
      <button type="button"><span class="binance-mark">B</span>Continue with Binance</button>
      <button type="button"><span class="wallet-mark">W</span>Continue with Wallet</button>
    </div>

    <form class="auth-form auth-signup-form" method="post" action="/auth/cadastro">
      <div class="auth-email-title"><span></span><b>OR CONTINUE WITH EMAIL</b><span></span></div>
      <input type="hidden" name="name" value="CryptoScope User">
      <label>Email Address<input name="email" type="email" placeholder="Enter your email address..." required></label>
      <label>Password<span><input name="password" type="password" placeholder="Enter your password..." required><i>hide</i></span></label>
      <label class="auth-check"><input type="checkbox" name="newsletter"><span>Please keep me updated by email with the latest crypto news, research findings, reward programs, event updates, coin listings and more information from CryptoScope.</span></label>
      <button class="auth-submit" type="submit">Create an account</button>
      <p class="auth-terms">By proceeding, you agree to CryptoScope's <a href="#">Terms of Use</a> & <a href="#">Privacy Policy</a>.</p>
    </form>
  </section>
</div>
